{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pyralis-labs.github.io/psu-power-build-planner/schemas/components.schema.json",
  "title": "PSU Power Build Planner components",
  "type": "object",
  "required": ["schemaVersion", "updatedAt", "components"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "updatedAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": ["id", "manufacturer", "model", "category", "power", "reviewedAt"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9.]+)*$" },
        "manufacturer": { "type": "string", "minLength": 1, "maxLength": 160 },
        "model": { "type": "string", "minLength": 1, "maxLength": 160 },
        "category": {
          "enum": ["platform", "cpu", "gpu", "memory", "storage", "cooling", "network", "accessory"]
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 160 }
        },
        "specifications": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "power": {
          "type": "object",
          "required": ["idle", "sustained", "transient"],
          "additionalProperties": false,
          "properties": {
            "idle": { "$ref": "#/$defs/sourced" },
            "sustained": { "$ref": "#/$defs/sourced" },
            "transient": { "$ref": "#/$defs/sourced" }
          }
        },
        "notes": { "type": "string", "maxLength": 2000 },
        "reviewedAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
      }
    },
    "sourced": {
      "type": "object",
      "required": ["watts", "basis", "confidence", "sourceIds"],
      "additionalProperties": false,
      "properties": {
        "watts": { "type": "number", "minimum": 0 },
        "basis": {
          "enum": [
            "measured-dc",
            "measured-wall-derived",
            "manufacturer-tbp",
            "manufacturer-tdp",
            "manufacturer-maximum",
            "review-estimate",
            "maintainer-estimate"
          ]
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9.]+)*$" }
        },
        "rationale": { "type": "string", "maxLength": 2000 }
      }
    }
  }
}
